# Local backend -> Docker Postgres:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/barcode_db
# Docker backend -> Docker Postgres:
# docker-compose overrides DATABASE_URL to postgresql+asyncpg://postgres:postgres@db:5432/barcode_db
SECRET_KEY=change-this-local-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
DEJAVU_SANS_FONT_PATH=

# local = local QazPostWeb passwords
# keycloak/external = users authenticate with Keycloak username/password.
# A local admin fallback is still allowed when LOCAL_ADMIN_LOGIN_ENABLED=true.
# hybrid = local users first, then Keycloak.
AUTH_MODE=local
LOCAL_ADMIN_LOGIN_ENABLED=true

KEYCLOAK_ISSUER_URI=
KEYCLOAK_TOKEN_URL=
KEYCLOAK_JWKS_URL=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_SCOPE=openid profile email
KEYCLOAK_AUDIENCE=
KEYCLOAK_USERNAME_CLAIM=preferred_username
KEYCLOAK_EMAIL_CLAIM=email
KEYCLOAK_FULL_NAME_CLAIM=name
KEYCLOAK_PHONE_CLAIM=phone_number
KEYCLOAK_AUTO_CREATE_USERS=true
KEYCLOAK_DEFAULT_ROLE=client

FILPASSPORT_DEPARTMENTS_URL=https://filpassport.kazpost.kz/api/barcodes/ltopdepid.jsn=9999&list=ofrupsall
FILPASSPORT_TIMEOUT_SECONDS=30

# Optional read-only integration with the official external SHPI PostgreSQL DB.
# Keep this disabled unless the read-only URL is available from the internal network.
# Example without SSL:
# OFFICIAL_SHPI_DATABASE_URL=postgresql+asyncpg://test_readonly:PASSWORD@172.30.110.5:5432/toolpar?sslmode=disable
# docker-compose reads these values from backend/.env too, so another developer only needs to edit one file.
OFFICIAL_SHPI_DB_ENABLED=false
OFFICIAL_SHPI_DATABASE_URL=
OFFICIAL_SHPI_TABLE=public.a_mail
OFFICIAL_SHPI_BARCODE_COLUMN=mail_id_
OFFICIAL_SHPI_DATE_COLUMN=mail_register_date_

APP_CONTEXT_PATH=
SERVER_PORT=8000
CORS_ORIGINS=
